{
  "name": "nami-tui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.13.0",
  "bin": {
    "nami": "bin/nami.js"
  },
  "scripts": {
    "build": "vp pack",
    "typecheck": "tsgo --noEmit",
    "start": "node bin/nami.js",
    "dev": "vp pack --watch",
    "install-engine": "cd .. && go build -o tui/engine/nami-engine ./cmd/nami-engine/",
    "setup": "vp run build && vp run install-engine"
  },
  "dependencies": {
    "cli-highlight": "^2.1.11",
    "silvery": "^0.19.2",
    "marked": "^15.0.12",
    "react": "^19.2.5",
    "react-devtools-core": "^7.0.1"
  },
  "overrides": {
    "@chenglou/pretext": "0.0.7"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260522.1",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.14",
    "vite-plus": "^0.1.22"
  }
}
